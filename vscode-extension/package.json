{
  "name": "azure-devops-mcp",
  "displayName": "Azure DevOps MCP Server",
  "description": "MCP server for Azure DevOps / TFS — guided setup with interactive prompts",
  "version": "1.0.6",
  "publisher": "vm3jack",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "mcp",
    "azure-devops",
    "tfs",
    "copilot",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vm3jack/mcp-server-azure-devops"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "azure-devops-mcp",
        "label": "Azure DevOps / TFS MCP Server"
      }
    ],
    "commands": [
      {
        "command": "azure-devops-mcp.reconfigure",
        "title": "Reconfigure",
        "category": "Azure DevOps MCP"
      }
    ],
    "configuration": {
      "title": "Azure DevOps MCP",
      "properties": {
        "adoMcp.orgUrl": {
          "type": "string",
          "description": "TFS / Azure DevOps Server URL (e.g. https://dev.azure.com/org or https://server/tfs/Collection)"
        },
        "adoMcp.authMethod": {
          "type": "string",
          "enum": ["pat", "azure-identity", "azure-cli"],
          "default": "pat",
          "enumDescriptions": [
            "Personal Access Token",
            "Azure Managed Identity / Workload Identity",
            "Azure CLI (az login)"
          ],
          "description": "Authentication method"
        },
        "adoMcp.pat": {
          "type": "string",
          "description": "Personal Access Token (PAT)"
        },
        "adoMcp.defaultProject": {
          "type": "string",
          "description": "Default project name (optional)"
        },
        "adoMcp.tlsMode": {
          "type": "string",
          "enum": ["1", "0"],
          "enumDescriptions": [
            "Standard TLS verification (default)",
            "Disable TLS verification (self-signed certificate)"
          ],
          "default": "1",
          "description": "TLS verification mode"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./ && esbuild ../src/index.ts --bundle --platform=node --target=node20 --outfile=out/server.js --external:vscode",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.3",
    "sharp": "^0.34.5",
    "typescript": "^5.8.2"
  }
}
